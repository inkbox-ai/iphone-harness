# Copy to .env in this directory (or in agent-workspace/.env) and fill in
# YOUR device's values. Both files are .gitignore'd by default.

# ---- Required ----

# Your iPhone's UDID. Find it with:
#   idevice_id -l                 (libimobiledevice — `brew install libimobiledevice`)
#   xcrun xctrace list devices    (Apple's tool, also lists offline devices)
IPH_UDID=YOUR-DEVICE-UDID-HERE

# Your Apple Developer Team ID (10 chars). Find it at:
#   developer.apple.com/account → Membership → Team ID
# Or: any of your Xcode signing identities will show it.
IPH_XCODE_ORG_ID=YOURTEAMID

# A bundle id YOU own/can sign, used for WebDriverAgent on the device.
# Pick anything reverse-domain that doesn't collide with a real app.
# Example: com.<your-handle>.iphone-harness.wda
IPH_WDA_BUNDLE_ID=com.example.iphone-harness.wda

# ---- Optional ----

# iOS version of the connected device — Appium can usually auto-detect.
# IPH_PLATFORM_VERSION=18.3.2

# A friendly name for the device. Anything works; only used in logs.
# IPH_DEVICE_NAME=My iPhone

# Where Appium is listening. Default is fine for a local install.
# IPH_APPIUM_URL=http://127.0.0.1:4723

# Daemon namespace — set distinct values to drive multiple phones in parallel.
# IPH_NAME=default

# Set to 1 to enable per-app skill discovery via domain_skills(bundle_id).
# IPH_DOMAIN_SKILLS=1

# Idle timeout for the Appium session in seconds. Bump if you have long pauses.
# IPH_NEW_COMMAND_TIMEOUT=600
